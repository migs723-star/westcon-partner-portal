<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Pricing & Margin Optimisation | Westcon AI</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg-1:#0f172a;
      --bg-2:#111827;
      --bg-3:#083344;
      --panel:rgba(255,255,255,0.06);
      --panel-strong:rgba(255,255,255,0.08);
      --line:rgba(255,255,255,0.10);
      --line-soft:rgba(255,255,255,0.06);
      --text:#e5eef7;
      --muted:#9fb0c7;
      --cyan:#22d3ee;
      --cyan-2:#06b6d4;
      --green:#22c55e;
      --amber:#f59e0b;
      --red:#ef4444;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --radius-xl:24px;
      --radius-lg:18px;
      --radius-md:14px;
    }

    body{
      font-family:Inter,Arial,sans-serif;
      background:linear-gradient(135deg,var(--bg-1) 0%,var(--bg-2) 45%,var(--bg-3) 100%);
      color:var(--text);
      min-height:100vh;
    }

    .container{
      max-width:1440px;
      margin:auto;
      padding:28px;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:18px 22px;
      border:1px solid var(--line);
      background:var(--panel);
      backdrop-filter:blur(14px);
      border-radius:20px;
      box-shadow:var(--shadow);
      margin-bottom:24px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .brand-badge{
      width:44px;
      height:44px;
      border-radius:14px;
      background:linear-gradient(135deg, rgba(34,211,238,.25), rgba(6,182,212,.10));
      border:1px solid rgba(34,211,238,.30);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:20px;
      box-shadow:inset 0 0 20px rgba(34,211,238,.15);
    }

    .brand-text h1{
      font-size:20px;
      font-weight:700;
      letter-spacing:.2px;
    }

    .brand-text p{
      margin-top:4px;
      color:var(--muted);
      font-size:13px;
    }

    .top-actions{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
    }

    .btn{
      border:none;
      cursor:pointer;
      padding:12px 16px;
      border-radius:12px;
      font-weight:600;
      font-size:14px;
      transition:.2s ease;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
    }

    .btn:hover{
      transform:translateY(-1px);
    }

    .btn-secondary{
      background:rgba(255,255,255,.05);
      color:var(--text);
      border:1px solid var(--line);
    }

    .btn-primary{
      background:linear-gradient(135deg,var(--cyan),var(--cyan-2));
      color:#06202b;
      box-shadow:0 10px 30px rgba(34,211,238,.25);
    }

    .hero{
      display:grid;
      grid-template-columns:1.3fr .9fr;
      gap:22px;
      margin-bottom:22px;
    }

    .hero-card, .stat-card, .panel{
      background:var(--panel);
      border:1px solid var(--line);
      border-radius:var(--radius-xl);
      backdrop-filter:blur(14px);
      box-shadow:var(--shadow);
    }

    .hero-main{
      padding:28px;
      position:relative;
      overflow:hidden;
    }

    .hero-main:before{
      content:"";
      position:absolute;
      right:-80px;
      top:-60px;
      width:220px;
      height:220px;
      background:radial-gradient(circle, rgba(34,211,238,.22) 0%, rgba(34,211,238,0) 70%);
      pointer-events:none;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(34,211,238,.25);
      background:rgba(34,211,238,.10);
      color:#baf6ff;
      font-size:12px;
      font-weight:700;
      letter-spacing:.4px;
      text-transform:uppercase;
      margin-bottom:14px;
    }

    .hero-main h2{
      font-size:34px;
      line-height:1.1;
      margin-bottom:12px;
      max-width:760px;
    }

    .hero-main p{
      color:var(--muted);
      line-height:1.6;
      max-width:760px;
      margin-bottom:22px;
    }

    .hero-highlights{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:14px;
    }

    .mini{
      padding:16px;
      border-radius:16px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line-soft);
    }

    .mini .label{
      color:var(--muted);
      font-size:12px;
      margin-bottom:6px;
    }

    .mini .value{
      font-size:20px;
      font-weight:700;
    }

    .hero-side{
      display:grid;
      grid-template-rows:repeat(3,1fr);
      gap:16px;
    }

    .stat-card{
      padding:20px;
    }

    .stat-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-bottom:18px;
    }

    .stat-label{
      color:var(--muted);
      font-size:13px;
    }

    .stat-value{
      font-size:28px;
      font-weight:800;
      margin-bottom:6px;
    }

    .trend{
      font-size:12px;
      font-weight:700;
    }

    .up{color:var(--green)}
    .warn{color:var(--amber)}
    .down{color:var(--red)}

    .progress{
      width:100%;
      height:10px;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      overflow:hidden;
    }

    .progress > span{
      display:block;
      height:100%;
      border-radius:999px;
      background:linear-gradient(135deg,var(--cyan),var(--cyan-2));
    }

    .layout{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:22px;
    }

    .panel{
      padding:24px;
    }

    .panel-head{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:16px;
      margin-bottom:20px;
    }

    .panel-head h3{
      font-size:22px;
      margin-bottom:6px;
    }

    .panel-head p{
      color:var(--muted);
      font-size:14px;
      line-height:1.5;
    }

    .chip{
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(34,211,238,.25);
      background:rgba(34,211,238,.10);
      color:#baf6ff;
      font-size:12px;
      font-weight:700;
      white-space:nowrap;
    }

    .form-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:16px;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .field.full{
      grid-column:1 / -1;
    }

    label{
      font-size:13px;
      font-weight:600;
      color:#dbe9f7;
    }

    input, select, textarea{
      width:100%;
      border:none;
      outline:none;
      padding:13px 14px;
      border-radius:14px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      color:var(--text);
      font-size:14px;
      transition:.2s ease;
    }

    input:focus, select:focus, textarea:focus{
      border-color:rgba(34,211,238,.45);
      box-shadow:0 0 0 3px rgba(34,211,238,.10);
    }

    select[multiple]{
      min-height:118px;
    }

    textarea{
      min-height:120px;
      resize:vertical;
    }

    .helper{
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
    }

    .form-actions{
      display:flex;
      gap:12px;
      margin-top:20px;
      flex-wrap:wrap;
    }

    .results{
      display:grid;
      gap:16px;
    }

    .score-card{
      padding:18px;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(34,211,238,.10), rgba(255,255,255,.03));
      border:1px solid rgba(34,211,238,.20);
    }

    .score-card .top{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
      margin-bottom:16px;
    }

    .score{
      font-size:42px;
      font-weight:800;
      line-height:1;
    }

    .score-sub{
      color:var(--muted);
      font-size:13px;
      margin-top:8px;
    }

    .badge{
      padding:8px 10px;
      border-radius:10px;
      font-size:12px;
      font-weight:700;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);
    }

    .kpis{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:12px;
      margin-top:12px;
    }

    .kpi{
      padding:14px;
      border-radius:14px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line-soft);
    }

    .kpi .k{
      color:var(--muted);
      font-size:12px;
      margin-bottom:6px;
    }

    .kpi .v{
      font-size:18px;
      font-weight:700;
    }

    .insight-list{
      display:grid;
      gap:12px;
    }

    .insight{
      padding:16px;
      border-radius:16px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line-soft);
    }

    .insight h4{
      font-size:15px;
      margin-bottom:6px;
    }

    .insight p{
      color:var(--muted);
      line-height:1.55;
      font-size:14px;
    }

    .table-wrap{
      overflow:auto;
      border-radius:16px;
      border:1px solid var(--line-soft);
    }

    table{
      width:100%;
      border-collapse:collapse;
      min-width:640px;
      background:rgba(255,255,255,.03);
    }

    th, td{
      padding:14px 16px;
      text-align:left;
      border-bottom:1px solid rgba(255,255,255,.06);
      font-size:14px;
    }

    th{
      color:#cbe4f4;
      font-size:12px;
      letter-spacing:.4px;
      text-transform:uppercase;
      background:rgba(255,255,255,.03);
    }

    .pill{
      display:inline-flex;
      align-items:center;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:700;
    }

    .pill.good{
      background:rgba(34,197,94,.14);
      color:#9ef0b7;
      border:1px solid rgba(34,197,94,.25);
    }

    .pill.mid{
      background:rgba(245,158,11,.14);
      color:#ffd28a;
      border:1px solid rgba(245,158,11,.25);
    }

    .pill.risk{
      background:rgba(239,68,68,.14);
      color:#ffadad;
      border:1px solid rgba(239,68,68,.25);
    }

    .footer-note{
      margin-top:18px;
      color:var(--muted);
      font-size:12px;
      line-height:1.6;
    }

    @media (max-width: 1120px){
      .hero,
      .layout{
        grid-template-columns:1fr;
      }

      .hero-side{
        grid-template-columns:repeat(3,1fr);
        grid-template-rows:none;
      }
    }

    @media (max-width: 860px){
      .hero-highlights,
      .form-grid,
      .kpis,
      .hero-side{
        grid-template-columns:1fr;
      }

      .topbar{
        flex-direction:column;
        align-items:flex-start;
      }

      .top-actions{
        width:100%;
      }

      .top-actions .btn{
        flex:1;
      }

      .hero-main h2{
        font-size:28px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="topbar">
      <div class="brand">
        <div class="brand-badge">💹</div>
        <div class="brand-text">
          <h1>AI Pricing & Margin Optimisation</h1>
          <p>Westcon AI Portal · Smart pricing guidance for partner deals</p>
        </div>
      </div>

      <div class="top-actions">
        <a href="userdashboard.html" class="btn btn-secondary">← Back to User Dashboard</a>
        <button class="btn btn-primary" id="runDemoTop">Run Demo Optimisation</button>
      </div>
    </header>

    <section class="hero">
      <div class="hero-card hero-main">
        <div class="eyebrow">Revenue Intelligence</div>
        <h2>Optimise pricing, protect margin, and improve win rate with AI-assisted deal strategy.</h2>
        <p>
          This workspace helps resellers and distributors evaluate customer pricing, suggested discount levels,
          expected margin impact, competitive positioning, and negotiation guidance before a quote is submitted.
        </p>

        <div class="hero-highlights">
          <div class="mini">
            <div class="label">Recommended Sell Price</div>
            <div class="value" id="heroSellPrice">$12,480</div>
          </div>
          <div class="mini">
            <div class="label">Projected Gross Margin</div>
            <div class="value" id="heroMargin">23.4%</div>
          </div>
          <div class="mini">
            <div class="label">Win Probability</div>
            <div class="value" id="heroWinRate">74%</div>
          </div>
        </div>
      </div>

      <div class="hero-side">
        <div class="stat-card">
          <div class="stat-top">
            <div class="stat-label">Margin Protection Score</div>
            <div class="trend up">+8.2%</div>
          </div>
          <div class="stat-value" id="marginScore">88 / 100</div>
          <div class="progress"><span id="marginBar" style="width:88%"></span></div>
        </div>

        <div class="stat-card">
          <div class="stat-top">
            <div class="stat-label">Discount Risk Index</div>
            <div class="trend warn">Moderate</div>
          </div>
          <div class="stat-value" id="discountRisk">31%</div>
          <div class="progress"><span id="riskBar" style="width:31%"></span></div>
        </div>

        <div class="stat-card">
          <div class="stat-top">
            <div class="stat-label">Competitiveness Position</div>
            <div class="trend up">Strong</div>
          </div>
          <div class="stat-value" id="competitiveness">Top Quartile</div>
          <div class="progress"><span id="compBar" style="width:79%"></span></div>
        </div>
      </div>
    </section>

    <section class="layout">
      <div class="panel">
        <div class="panel-head">
          <div>
            <h3>Deal Input Form</h3>
            <p>Capture deal variables that affect pricing, margin, discounting, and sales strategy.</p>
          </div>
          <div class="chip">Input Driven</div>
        </div>

        <form id="pricingForm">
          <div class="form-grid">
            <div class="field">
              <label for="customerName">Customer Name</label>
              <input id="customerName" type="text" placeholder="e.g. ABC Financial Services" />
            </div>

            <div class="field">
              <label for="region">Region</label>
              <select id="region">
                <option>South Africa</option>
                <option>Sub-Saharan Africa</option>
                <option>Middle East</option>
                <option>Europe</option>
                <option>Global</option>
              </select>
            </div>

            <div class="field">
              <label for="industry">Industry</label>
              <select id="industry">
                <option>Financial Services</option>
                <option>Healthcare</option>
                <option>Retail</option>
                <option>Education</option>
                <option>Manufacturing</option>
                <option>Government</option>
                <option>Telecommunications</option>
              </select>
            </div>

            <div class="field">
              <label for="dealType">Deal Type</label>
              <select id="dealType">
                <option>New Business</option>
                <option>Renewal</option>
                <option>Upsell</option>
                <option>Cross-sell</option>
                <option>Strategic Bid</option>
              </select>
            </div>

            <div class="field">
              <label for="vendor">Vendor / Solution</label>
              <select id="vendor">
                <option>Cisco Security</option>
                <option>Cisco Networking</option>
                <option>Microsoft Cloud</option>
                <option>AWS</option>
                <option>Palo Alto</option>
                <option>Fortinet</option>
              </select>
            </div>

            <div class="field">
              <label for="currency">Currency</label>
              <select id="currency">
                <option>USD</option>
                <option>ZAR</option>
                <option>EUR</option>
                <option>GBP</option>
              </select>
            </div>

            <div class="field">
              <label for="costPrice">Base Cost Price</label>
              <input id="costPrice" type="number" step="0.01" value="9800" placeholder="e.g. 9800" />
            </div>

            <div class="field">
              <label for="targetMargin">Target Margin %</label>
              <input id="targetMargin" type="number" step="0.1" value="24" placeholder="e.g. 24" />
            </div>

            <div class="field">
              <label for="competitorPrice">Competitor Price</label>
              <input id="competitorPrice" type="number" step="0.01" value="12650" placeholder="e.g. 12650" />
            </div>

            <div class="field">
              <label for="dealValue">Expected Deal Value</label>
              <input id="dealValue" type="number" step="0.01" value="15000" placeholder="e.g. 15000" />
            </div>

            <div class="field">
              <label for="volume">Unit Volume / Licenses</label>
              <input id="volume" type="number" value="250" placeholder="e.g. 250" />
            </div>

            <div class="field">
              <label for="discountBand">Requested Discount %</label>
              <input id="discountBand" type="number" step="0.1" value="7.5" placeholder="e.g. 7.5" />
            </div>

            <div class="field">
              <label for="strategic">Strategic Importance</label>
              <select id="strategic">
                <option>High</option>
                <option selected>Medium</option>
                <option>Low</option>
              </select>
            </div>

            <div class="field">
              <label for="urgency">Sales Urgency</label>
              <select id="urgency">
                <option>Immediate</option>
                <option selected>This Quarter</option>
                <option>Next Quarter</option>
                <option>Long Cycle</option>
              </select>
            </div>

            <div class="field full">
              <label for="services">Attached Services / Value Drivers</label>
              <select id="services" multiple>
                <option selected>Implementation Services</option>
                <option selected>Managed Support</option>
                <option>Training</option>
                <option>Advisory / Consulting</option>
                <option>Financing Options</option>
                <option>Renewal Assurance</option>
              </select>
              <div class="helper">Hold Ctrl / Cmd to select multiple options.</div>
            </div>

            <div class="field full">
              <label for="notes">Commercial Notes</label>
              <textarea id="notes" placeholder="Add deal context, buying signals, negotiation pressure, executive sponsorship, competitor threats, or renewal risks.">Customer is comparing 2 vendors and wants bundled support. Account is strategically important for future cloud expansion.</textarea>
            </div>
          </div>

          <div class="form-actions">
            <button type="button" class="btn btn-primary" id="runDemo">Generate Recommendation</button>
            <button type="reset" class="btn btn-secondary">Reset Fields</button>
            <a href="userdashboard.html" class="btn btn-secondary">Back</a>
          </div>
        </form>

        <div class="footer-note">
          Suggested use: capture current deal economics, compare margin scenarios, and guide account teams toward a smarter quote range before submitting approvals.
        </div>
      </div>

      <div class="results">
        <div class="panel score-card">
          <div class="top">
            <div>
              <div class="score" id="scoreValue">88</div>
              <div class="score-sub">AI Optimisation Score</div>
            </div>
            <div class="badge" id="scoreBadge">Healthy Margin Position</div>
          </div>

          <div class="kpis">
            <div class="kpi">
              <div class="k">Suggested Sell Price</div>
              <div class="v" id="sellPrice">$12,480</div>
            </div>
            <div class="kpi">
              <div class="k">Gross Margin</div>
              <div class="v" id="grossMargin">23.4%</div>
            </div>
            <div class="kpi">
              <div class="k">Win Probability</div>
              <div class="v" id="winProb">74%</div>
            </div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <div>
              <h3>AI Recommendations</h3>
              <p>Actionable pricing guidance based on commercial inputs.</p>
            </div>
            <div class="chip">Decision Support</div>
          </div>

          <div class="insight-list" id="insights">
            <div class="insight">
              <h4>Price slightly below the competitor while protecting target margin.</h4>
              <p>Suggested quote positioning is close enough to stay competitive without giving away unnecessary discount on the first pass.</p>
            </div>
            <div class="insight">
              <h4>Bundle managed support to justify commercial value.</h4>
              <p>Packaging support and implementation can improve deal defensibility and reduce direct price comparison pressure.</p>
            </div>
            <div class="insight">
              <h4>Escalate only if discount exceeds the safe threshold.</h4>
              <p>Any move beyond the recommended discount band should require commercial approval because margin erosion increases sharply after that point.</p>
            </div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <div>
              <h3>Scenario Comparison</h3>
              <p>Illustrative pricing paths for the current opportunity.</p>
            </div>
            <div class="chip">What-if Analysis</div>
          </div>

          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Scenario</th>
                  <th>Sell Price</th>
                  <th>Margin</th>
                  <th>Win Likelihood</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="scenarioTable">
                <tr>
                  <td>Protect Margin</td>
                  <td>$12,900</td>
                  <td>24.0%</td>
                  <td>68%</td>
                  <td><span class="pill good">Recommended</span></td>
                </tr>
                <tr>
                  <td>Balanced Offer</td>
                  <td>$12,480</td>
                  <td>23.4%</td>
                  <td>74%</td>
                  <td><span class="pill good">Strong</span></td>
                </tr>
                <tr>
                  <td>Aggressive Discount</td>
                  <td>$11,990</td>
                  <td>18.3%</td>
                  <td>81%</td>
                  <td><span class="pill mid">Review</span></td>
                </tr>
                <tr>
                  <td>Below Threshold</td>
                  <td>$11,350</td>
                  <td>13.7%</td>
                  <td>84%</td>
                  <td><span class="pill risk">At Risk</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    function formatCurrency(value, currency){
      try{
        return new Intl.NumberFormat('en-US', {
          style:'currency',
          currency: currency || 'USD',
          maximumFractionDigits:0
        }).format(value);
      }catch(e){
        return '$' + Math.round(value).toLocaleString();
      }
    }

    function generateRecommendation(){
      const currency = document.getElementById('currency').value || 'USD';
      const cost = parseFloat(document.getElementById('costPrice').value) || 0;
      const targetMargin = parseFloat(document.getElementById('targetMargin').value) || 0;
      const competitor = parseFloat(document.getElementById('competitorPrice').value) || 0;
      const requestedDiscount = parseFloat(document.getElementById('discountBand').value) || 0;
      const strategic = document.getElementById('strategic').value;
      const dealType = document.getElementById('dealType').value;
      const urgency = document.getElementById('urgency').value;

      let baseSell = cost / (1 - (targetMargin / 100 || 0.24));
      if (!isFinite(baseSell) || baseSell <= 0) baseSell = cost * 1.24;

      let recommendedSell = baseSell;

      if (competitor > 0) {
        recommendedSell = Math.min(baseSell, competitor * 0.986);
        recommendedSell = Math.max(recommendedSell, cost * 1.16);
      }

      if (requestedDiscount > 10) recommendedSell *= 0.985;
      if (strategic === 'High') recommendedSell *= 0.99;
      if (dealType === 'Renewal') recommendedSell *= 0.995;
      if (urgency === 'Immediate') recommendedSell *= 0.993;

      const margin = ((recommendedSell - cost) / recommendedSell) * 100;
      const competitivenessGap = competitor > 0 ? ((competitor - recommendedSell) / competitor) * 100 : 1.5;
      let winProbability = 65 + Math.max(0, competitivenessGap * 3.2);

      if (strategic === 'High') winProbability += 4;
      if (dealType === 'Renewal') winProbability += 3;
      if (requestedDiscount > 12) winProbability += 2;
      if (margin < 18) winProbability -= 4;

      winProbability = Math.max(45, Math.min(91, winProbability));

      let score = Math.round((margin * 2.6) + (winProbability * 0.45));
      score = Math.max(52, Math.min(96, score));

      const risk = Math.max(8, Math.min(79, Math.round((requestedDiscount * 2.8) + (margin < 18 ? 15 : 0))));
      const competitiveness = Math.max(45, Math.min(95, Math.round(68 + competitivenessGap * 6)));

      document.getElementById('sellPrice').textContent = formatCurrency(recommendedSell, currency);
      document.getElementById('grossMargin').textContent = margin.toFixed(1) + '%';
      document.getElementById('winProb').textContent = Math.round(winProbability) + '%';
      document.getElementById('scoreValue').textContent = score;

      document.getElementById('heroSellPrice').textContent = formatCurrency(recommendedSell, currency);
      document.getElementById('heroMargin').textContent = margin.toFixed(1) + '%';
      document.getElementById('heroWinRate').textContent = Math.round(winProbability) + '%';

      document.getElementById('marginScore').textContent = score + ' / 100';
      document.getElementById('discountRisk').textContent = risk + '%';
      document.getElementById('competitiveness').textContent = competitiveness >= 78 ? 'Top Quartile' : competitiveness >= 62 ? 'Competitive' : 'Needs Attention';

      document.getElementById('marginBar').style.width = score + '%';
      document.getElementById('riskBar').style.width = risk + '%';
      document.getElementById('compBar').style.width = competitiveness + '%';

      const badge = document.getElementById('scoreBadge');
      if (margin >= 22){
        badge.textContent = 'Healthy Margin Position';
      } else if (margin >= 18){
        badge.textContent = 'Balanced Trade-off';
      } else {
        badge.textContent = 'Margin Pressure Detected';
      }

      const insights = document.getElementById('insights');
      insights.innerHTML = `
        <div class="insight">
          <h4>${margin >= 22 ? 'Protect the current price corridor.' : 'Adjust quote structure to recover margin.'}</h4>
          <p>${margin >= 22
            ? 'The current recommendation keeps the deal competitive while remaining above a healthy gross margin threshold.'
            : 'The requested commercial position is starting to compress margin. Consider reducing discount or increasing bundled value.'}
          </p>
        </div>
        <div class="insight">
          <h4>${competitor > 0 ? 'Position the quote against competitor pressure.' : 'Use value-led pricing.'}</h4>
          <p>${competitor > 0
            ? `Recommended pricing is set ${Math.abs(competitivenessGap).toFixed(1)}% ${competitivenessGap >= 0 ? 'below' : 'above'} the competitor reference to improve deal attractiveness without over-discounting.`
            : 'No competitor benchmark was provided, so the recommendation leans on target margin, urgency, and strategic value.'}
          </p>
        </div>
        <div class="insight">
          <h4>${requestedDiscount > 10 ? 'Approval workflow is advisable.' : 'Discount remains within a safer band.'}</h4>
          <p>${requestedDiscount > 10
            ? 'The requested discount level is high enough to justify a commercial review before final submission, especially if services are not attached.'
            : 'Current discount input stays within a more controlled range and should be easier to defend internally.'}
          </p>
        </div>
      `;

      const protect = baseSell;
      const balanced = recommendedSell;
      const aggressive = Math.max(cost * 1.183, recommendedSell * 0.961);
      const below = Math.max(cost * 1.137, recommendedSell * 0.91);

      document.getElementById('scenarioTable').innerHTML = `
        <tr>
          <td>Protect Margin</td>
          <td>${formatCurrency(protect, currency)}</td>
          <td>${(((protect - cost)/protect)*100).toFixed(1)}%</td>
          <td>${Math.max(58, Math.round(winProbability - 6))}%</td>
          <td><span class="pill good">Recommended</span></td>
        </tr>
        <tr>
          <td>Balanced Offer</td>
          <td>${formatCurrency(balanced, currency)}</td>
          <td>${margin.toFixed(1)}%</td>
          <td>${Math.round(winProbability)}%</td>
          <td><span class="pill good">Strong</span></td>
        </tr>
        <tr>
          <td>Aggressive Discount</td>
          <td>${formatCurrency(aggressive, currency)}</td>
          <td>${(((aggressive - cost)/aggressive)*100).toFixed(1)}%</td>
          <td>${Math.min(92, Math.round(winProbability + 6))}%</td>
          <td><span class="pill mid">Review</span></td>
        </tr>
        <tr>
          <td>Below Threshold</td>
          <td>${formatCurrency(below, currency)}</td>
          <td>${(((below - cost)/below)*100).toFixed(1)}%</td>
          <td>${Math.min(94, Math.round(winProbability + 9))}%</td>
          <td><span class="pill risk">At Risk</span></td>
        </tr>
      `;
    }

    document.getElementById('runDemo').addEventListener('click', generateRecommendation);
    document.getElementById('runDemoTop').addEventListener('click', generateRecommendation);

    document.getElementById('pricingForm').addEventListener('reset', function(){
      setTimeout(generateRecommendation, 20);
    });

    window.addEventListener('load', generateRecommendation);
  </script>
</body>
</html>
