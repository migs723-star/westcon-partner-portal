<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Security Threat Intelligence Dashboard</title>

<style>
*{box-sizing:border-box;margin:0;padding:0}

body{
font-family:Inter,Arial,sans-serif;
background:linear-gradient(135deg,#0f172a 0%,#111827 45%,#083344 100%);
color:#e5eef7;
min-height:100vh;
}

.container{max-width:1400px;margin:auto;padding:28px}

/* HEADER */
.topbar{
display:flex;justify-content:space-between;align-items:center;
padding:18px 24px;border-radius:18px;
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
margin-bottom:25px;
}

.brand{display:flex;align-items:center;gap:12px}
.badge{
width:42px;height:42px;border-radius:12px;
background:rgba(34,211,238,0.2);
display:flex;align-items:center;justify-content:center;
}

.pill{
padding:8px 14px;border-radius:999px;
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
font-size:12px;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:1.4fr 1fr 1fr;
gap:18px;
}

/* CARD */
.card{
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
border-radius:18px;
padding:18px;
}

/* TIMELINE */
.timeline{max-height:600px;overflow:auto;display:flex;flex-direction:column;gap:12px}

.event{
background:rgba(255,255,255,0.04);
padding:14px;border-radius:14px;
border:1px solid rgba(255,255,255,0.07);
}

.critical{border-left:4px solid #ef4444}
.high{border-left:4px solid #f59e0b}
.medium{border-left:4px solid #3b82f6}
.low{border-left:4px solid #22c55e}

/* FORM */
input,select,textarea{
width:100%;
padding:10px;
border-radius:10px;
border:1px solid rgba(255,255,255,0.08);
background:rgba(255,255,255,0.05);
color:#fff;
margin-bottom:10px;
}

button{
padding:10px;
border:none;
border-radius:10px;
cursor:pointer;
}

.primary{
background:linear-gradient(135deg,#06b6d4,#2563eb);
color:#fff;
}

/* CHAT */
.chat{
display:flex;
flex-direction:column;
height:600px;
}

.messages{
flex:1;
overflow:auto;
display:flex;
flex-direction:column;
gap:10px;
margin-bottom:10px;
}

.msg{
padding:10px;
border-radius:12px;
max-width:80%;
}

.user{align-self:flex-end;background:#2563eb}
.bot{align-self:flex-start;background:rgba(255,255,255,0.1)}

textarea{height:70px}
</style>
</head>

<body>

<div class="container">

<div class="topbar">
<div class="brand">
<div class="badge">🛡️</div>
<div>
<h2>AI Threat Intelligence</h2>
<p style="font-size:12px;color:#9fb3c8">Live SOC Dashboard</p>
</div>
</div>

<div style="display:flex;gap:10px">
<div class="pill">Live</div>
<div class="pill">AI Confidence 94%</div>
</div>
</div>

<div class="grid">

<!-- TIMELINE -->
<div class="card">
<h3>Threat Timeline</h3>
<div class="timeline" id="timeline"></div>
</div>

<!-- FORM -->
<div>
<div class="card">
<h3>New Threat</h3>

<form id="form">
<input value="SRV-FIN-01" id="asset">
<select id="type">
<option>Ransomware</option>
<option>Phishing</option>
<option>Credential Abuse</option>
</select>

<select id="severity">
<option>Low</option>
<option>Medium</option>
<option>High</option>
<option selected>Critical</option>
</select>

<textarea id="notes">Suspicious encryption activity detected</textarea>

<button class="primary" type="submit">Create Case</button>
</form>
</div>
</div>

<!-- CHAT -->
<div class="card chat">
<h3>AI Copilot</h3>

<div class="messages" id="chat"></div>

<textarea id="input"></textarea>
<button class="primary" onclick="send()">Send</button>

</div>

</div>

</div>

<script>
const timeline = document.getElementById("timeline");
const chat = document.getElementById("chat");

function addEvent(e){
const div = document.createElement("div");
div.className = "event " + e.severity.toLowerCase();
div.innerHTML = `
<b>${e.title}</b><br>
<small>${e.time}</small><br>
${e.desc}
`;
timeline.prepend(div);
}

function now(){
return new Date().toLocaleTimeString();
}

/* DUMMY DATA */
[
{severity:"Critical",title:"Ransomware Detected",desc:"Encryption pattern found",time:"09:12"},
{severity:"High",title:"Suspicious Login",desc:"Impossible travel detected",time:"09:08"},
{severity:"Medium",title:"Beaconing",desc:"Outbound traffic anomaly",time:"08:54"}
].forEach(addEvent);

/* AUTO EVENTS */
setInterval(()=>{
const threats=[
"Credential abuse detected",
"Lateral movement attempt",
"Malware callback detected",
"Data exfiltration suspected"
];

const sev=["Low","Medium","High","Critical"];

addEvent({
severity:sev[Math.floor(Math.random()*4)],
title:threats[Math.floor(Math.random()*4)],
desc:"AI generated threat event",
time:now()
});
},20000);

/* FORM */
document.getElementById("form").addEventListener("submit",e=>{
e.preventDefault();

addEvent({
severity:severity.value,
title:type.value+" on "+asset.value,
desc:notes.value,
time:now()
});
});

/* CHAT */
function addMsg(type,text){
const m=document.createElement("div");
m.className="msg "+type;
m.innerText=text;
chat.appendChild(m);
chat.scrollTop=chat.scrollHeight;
}

function send(){
const val=input.value;
if(!val)return;

addMsg("user",val);
input.value="";

setTimeout(()=>{
addMsg("bot","AI Response:\\nReview critical threats and isolate affected systems.");
},500);
}
</script>

</body>
</html>
