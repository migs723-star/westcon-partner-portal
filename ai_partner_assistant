function setFlowStep(index) {
  flowSteps.forEach((step, i) => {
    step.classList.toggle('active', i === 0 && index === 0);
    step.classList.toggle('current', i === index);
  });
}

function runThinkingAnimation() {
  let current = 0;
  setFlowStep(1);
  thinkingSteps.forEach((li, i) => li.classList.toggle('active', i === 0));

  return new Promise((resolve) => {
    const interval = setInterval(() => {
      thinkingSteps.forEach((li, i) => li.classList.toggle('active', i === current));
      const flowIndex = Math.min(current + 1, 3);
      setFlowStep(flowIndex);
      current += 1;
      if (current === thinkingSteps.length) {
        clearInterval(interval);
        setTimeout(resolve, 450);
      }
    }, 650);
  });
}

