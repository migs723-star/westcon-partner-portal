  document.getElementById('proposalExecutive').textContent = industryData.executive;
  document.getElementById('proposalOutcome').textContent = industryData.outcome;
  document.getElementById('proposalRationale').textContent = industryData.rationale || industryData.architecture;

  const stack = document.getElementById('proposalStack');
  stack.innerHTML = '';
  [
    `${industryData.network[0]} — ${industryData.network[1]}`,
    `${industryData.security[0]} — ${industryData.security[1]}`,
    `${industryData.endpoint[0]} — ${industryData.endpoint[1]}`,
