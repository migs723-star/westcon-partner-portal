}

function resetDemo() {
  form.reset();
  proposalModal.classList.add('hidden');
  proposalModal.setAttribute('aria-hidden', 'true');
  thinkingState.classList.add('hidden');
  resultsState.classList.add('hidden');
  emptyState.classList.remove('hidden');
  setFlowStep(0);
}

