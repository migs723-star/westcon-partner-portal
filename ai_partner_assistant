<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Westcon AI Partner Assistant Demo</title>
  <style>
:root {
  --bg: #08111b;
  --bg-alt: #0d1623;
  --panel: rgba(255, 255, 255, 0.06);
  --panel-border: rgba(255, 255, 255, 0.12);
  --text: #e7eef8;
  --muted: #9fb1c8;
  --primary: #00c4c4;
  --primary-2: #2e90ff;
  --success: #17c964;
  --warning: #ffd166;
  --shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  --radius: 24px;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: Inter, Arial, sans-serif;
  color: var(--text);
  background:
    radial-gradient(circle at top left, rgba(0,196,196,0.15), transparent 28%),
    radial-gradient(circle at bottom right, rgba(46,144,255,0.14), transparent 30%),
    linear-gradient(135deg, #071018 0%, #0a131f 45%, #0c1a28 100%);
  min-height: 100vh;
  overflow-x: hidden;
}

.bg-grid,
.bg-orb {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.bg-grid {
  background-image:
    linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: radial-gradient(circle at center, rgba(0,0,0,0.9), transparent 85%);
}

.bg-orb {
  width: 520px;
  height: 520px;
  border-radius: 50%;
  filter: blur(90px);
  opacity: 0.35;
}

.orb-1 {
  background: rgba(0, 196, 196, 0.35);
  top: -120px;
  left: -140px;
}

.orb-2 {
  background: rgba(46, 144, 255, 0.28);
  right: -180px;
  bottom: -180px;
}

.shell {
  position: relative;
  z-index: 1;
  width: min(1440px, calc(100% - 32px));
  margin: 20px auto;
}

.glass {
  background: var(--panel);
  border: 1px solid var(--panel-border);
  box-shadow: var(--shadow);
  backdrop-filter: blur(16px);
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 22px;
  border-radius: 22px;
  margin-bottom: 18px;
  gap: 16px;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 14px;
}

.brand-mark {
  width: 54px;
  height: 54px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  font-size: 24px;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  color: white;
}

.eyebrow,
.section-label,
.solution-type,
.summary-label {
  display: inline-block;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 11px;
  color: var(--primary);
}

.topbar h1,
.hero h2,
.card-head h3,
.stage-head h3,
.timeline h3,
.modal-head h3 {
  margin: 4px 0 0;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.status-pill,
.micro-tag,
.mini-badge {
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.05);
  color: var(--text);
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
}

.dot {
  width: 8px;
  height: 8px;
  display: inline-block;
  border-radius: 50%;
  margin-right: 8px;
  background: var(--success);
  box-shadow: 0 0 0 6px rgba(23, 201, 100, 0.15);
}

.ghost-btn,
.secondary-btn,
.icon-btn {
  border: 1px solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.04);
  color: var(--text);
  border-radius: 14px;
  padding: 12px 16px;
  cursor: pointer;
  transition: 0.2s ease;
}

.ghost-btn:hover,
.secondary-btn:hover,
.icon-btn:hover {
  transform: translateY(-1px);
  background: rgba(255,255,255,0.08);
}

.primary-btn {
  border: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  color: white;
  border-radius: 14px;
  padding: 13px 18px;
  cursor: pointer;
  font-weight: 600;
  transition: 0.2s ease;
}

.primary-btn:hover { transform: translateY(-1px) scale(1.01); }

.layout {
  display: grid;
  grid-template-columns: 1.08fr 0.92fr;
  gap: 18px;
}

.left-panel,
.right-panel {
  display: grid;
  gap: 18px;
}

.hero,
.input-card,
.demo-stage,
.timeline,
.modal-card {
  border-radius: var(--radius);
}

.hero {
  padding: 28px;
}

.hero h2 {
  font-size: clamp(28px, 3vw, 42px);
  line-height: 1.05;
}

.hero p,
.empty-state p,
.insight-panel p,
.proposal-block p,
.solution-card p,
.flow-step strong,
label span,
.thinking-steps li,
.card-head p {
  color: var(--muted);
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 22px;
}

.metric-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px;
  padding: 18px;
}

.metric-card.accent {
  background: linear-gradient(135deg, rgba(0,196,196,0.12), rgba(46,144,255,0.14));
}

.metric-value {
  display: block;
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 6px;
}

.metric-label { font-size: 13px; color: var(--muted); }

.input-card,
.demo-stage,
.timeline {
  padding: 24px;
}

.card-head,
.stage-head,
.modal-head {
  display: flex;
  justify-content: space-between;
  align-items: start;
  gap: 16px;
  margin-bottom: 18px;
}

.card-head.compact { margin-bottom: 14px; }

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.full-width { grid-column: 1 / -1; }

label {
  display: grid;
  gap: 8px;
}

select,
input {
  width: 100%;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(8, 17, 27, 0.75);
  color: var(--text);
  padding: 14px 14px;
  outline: none;
}

select:focus,
input:focus {
  border-color: rgba(0,196,196,0.7);
  box-shadow: 0 0 0 4px rgba(0,196,196,0.12);
}

.button-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.empty-state,
.thinking-state {
  min-height: 480px;
  display: grid;
  place-items: center;
  text-align: center;
}

.empty-icon {
  width: 78px;
  height: 78px;
  margin: 0 auto 12px;
  border-radius: 22px;
  display: grid;
  place-items: center;
  font-size: 32px;
  background: linear-gradient(135deg, rgba(0,196,196,0.2), rgba(46,144,255,0.22));
}

.thinking-state {
  grid-template-columns: 100px 1fr;
  gap: 28px;
  text-align: left;
  padding: 42px 12px;
}

.thinking-ring {
  width: 82px;
  height: 82px;
  border-radius: 50%;
  border: 4px solid rgba(255,255,255,0.08);
  border-top-color: var(--primary);
  border-right-color: var(--primary-2);
  animation: spin 1.05s linear infinite;
}

.thinking-steps {
  list-style: none;
  padding: 0;
  margin: 14px 0 0;
  display: grid;
  gap: 10px;
}

.thinking-steps li {
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
}

.thinking-steps li.active {
  border-color: rgba(0,196,196,0.45);
  color: var(--text);
  background: rgba(0,196,196,0.08);
}

.results-state {
  display: grid;
  gap: 18px;
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-radius: 18px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
}

.solution-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}

.solution-card {
  display: grid;
  grid-template-columns: 58px 1fr;
  gap: 14px;
  padding: 18px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.045);
}

.solution-card.network { box-shadow: inset 0 0 0 1px rgba(46,144,255,0.12); }
.solution-card.security { box-shadow: inset 0 0 0 1px rgba(255,209,102,0.15); }
.solution-card.endpoint { box-shadow: inset 0 0 0 1px rgba(23,201,100,0.12); }
.solution-card.identity { box-shadow: inset 0 0 0 1px rgba(0,196,196,0.15); }

.solution-icon {
  width: 58px;
  height: 58px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  font-size: 26px;
  background: rgba(255,255,255,0.06);
}

.solution-card h4,
.insight-panel h4,
.proposal-block h4 {
  margin: 6px 0 8px;
}

.insight-panels {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 14px;
}

.insight-panel {
  padding: 18px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
}

.revenue-panel {
  background: linear-gradient(135deg, rgba(23,201,100,0.11), rgba(0,196,196,0.08));
}

.flow-line {
  display: grid;
  gap: 12px;
}

.flow-step {
  display: grid;
  grid-template-columns: 42px 1fr;
  align-items: center;
  gap: 12px;
  padding: 14px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.035);
}

.flow-step span {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 700;
  background: rgba(255,255,255,0.06);
}

.flow-step.active,
.flow-step.current {
  border-color: rgba(0,196,196,0.42);
  background: rgba(0,196,196,0.08);
}

.modal {
  position: fixed;
  inset: 0;
  background: rgba(2, 7, 12, 0.72);
  display: grid;
  place-items: center;
  z-index: 20;
  padding: 20px;
}

.modal-card {
  width: min(960px, 100%);
  padding: 24px;
}

.proposal-body {
  display: grid;
  gap: 16px;
}

.proposal-block {
  padding: 18px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

#proposalStack {
  margin: 0;
  padding-left: 18px;
  color: var(--muted);
}

.hidden { display: none !important; }

@keyframes spin { to { transform: rotate(360deg); } }

@media (max-width: 1100px) {
  .layout,
  .solution-grid,
  .insight-panels,
  .two-col,
  .hero-metrics {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 760px) {
  .shell { width: min(100% - 16px, 1440px); }
  .topbar,
  .summary-bar,
  .card-head,
  .stage-head,
  .modal-head,
  .thinking-state {
    grid-template-columns: 1fr;
    display: grid;
  }
  .form-grid { grid-template-columns: 1fr; }
  .button-row { flex-direction: column; }
}


.modal-card {
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}

.modal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-bottom: 14px;
}

.proposal-body {
  overflow-y: auto;
  max-height: calc(88vh - 110px);
  padding-right: 10px;
}

.custom-scroll::-webkit-scrollbar {
  width: 10px;
}

.custom-scroll::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.04);
  border-radius: 999px;
}

.custom-scroll::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, rgba(0,196,196,0.95), rgba(46,144,255,0.95));
  border-radius: 999px;
  border: 2px solid rgba(8,17,27,0.65);
}

.custom-scroll {
  scrollbar-width: thin;
  scrollbar-color: rgba(0,196,196,0.95) rgba(255,255,255,0.04);
}

.proposal-meta-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.meta-chip {
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.035);
}

.meta-chip span {
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--primary);
  margin-bottom: 6px;
}

.meta-chip strong {
  display: block;
  color: var(--text);
  font-size: 14px;
  line-height: 1.35;
}

.proposal-block ul {
  margin: 0;
  padding-left: 18px;
  display: grid;
  gap: 10px;
  color: var(--muted);
}

.proposal-block li {
  line-height: 1.5;
}

@media (max-width: 1100px) {
  .proposal-meta-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 760px) {
  .proposal-meta-grid {
    grid-template-columns: 1fr;
  }

  .proposal-body {
    max-height: calc(88vh - 120px);
  }
}
  </style>
</head>
<body>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-grid"></div>

  <div class="shell">
    <header class="topbar glass">
      <div class="brand-wrap">
        <div class="brand-mark">W</div>
        <div>
          <div class="eyebrow">Strategic Demo</div>
          <h1>Westcon AI Partner Assistant</h1>
        </div>
      </div>
      <div class="top-actions">
        <span class="status-pill"><span class="dot"></span> Live Demo Mode</span>
        <button class="ghost-btn" id="resetBtn" type="button">Reset Demo</button>
      </div>
    </header>

    <main class="layout">
      <section class="left-panel">
        <div class="hero glass">
          <div class="hero-copy">
            <span class="section-label">AI-Enabled Channel Growth</span>
            <h2>Every partner gets the knowledge of your best engineer. Instantly.</h2>
            <p>
              This demo shows how a partner can describe a customer need, receive a vendor-aligned
              solution recommendation in seconds, and generate a proposal-ready output.
            </p>
          </div>
          <div class="hero-metrics">
            <div class="metric-card">
              <span class="metric-value">+30%</span>
              <span class="metric-label">Faster Deal Cycles</span>
            </div>
            <div class="metric-card">
              <span class="metric-value">-40%</span>
              <span class="metric-label">Presales Load</span>
            </div>
            <div class="metric-card accent">
              <span class="metric-value">24/7</span>
              <span class="metric-label">Partner Enablement</span>
            </div>
          </div>
        </div>

        <div class="input-card glass">
          <div class="card-head">
            <div>
              <span class="section-label">Partner Input</span>
              <h3>Generate a solution recommendation</h3>
            </div>
            <span class="micro-tag">Demo workflow</span>
          </div>

          <form id="solutionForm" class="form-grid">
            <label>
              <span>Industry</span>
              <select id="industry" name="industry" required>
                <option value="">Select industry</option>
                <option value="Banking">Banking</option>
                <option value="Healthcare">Healthcare</option>
                <option value="Retail">Retail</option>
                <option value="Insurance">Insurance</option>
                <option value="Telecommunications">Telecommunications</option>
                <option value="Education">Education</option>
                <option value="Manufacturing">Manufacturing</option>
              </select>
            </label>

            <label>
              <span>Users</span>
              <input id="users" name="users" type="number" min="1" placeholder="e.g. 2000" required />
            </label>

            <label class="full-width">
              <span>Primary Requirement</span>
              <input id="requirement" name="requirement" type="text" placeholder="e.g. Secure hybrid workforce" required />
            </label>

            <label>
              <span>Budget</span>
              <input id="budget" name="budget" type="text" placeholder="e.g. $300k" required />
            </label>

            <label>
              <span>Cloud Strategy</span>
              <select id="cloud" name="cloud" required>
                <option value="">Select strategy</option>
                <option value="On-premise">On-premise</option>
                <option value="Private cloud">Private cloud</option>
                <option value="Public cloud">Public cloud</option>
                <option value="Hybrid cloud">Hybrid cloud</option>
                <option value="Multi-cloud">Multi-cloud</option>
              </select>
            </label>

            <label>
              <span>Priority Outcome</span>
              <select id="priority" name="priority" required>
                <option value="">Select priority</option>
                <option value="Security resilience">Security resilience</option>
                <option value="Performance and uptime">Performance and uptime</option>
                <option value="Compliance and governance">Compliance and governance</option>
                <option value="Scalability">Scalability</option>
                <option value="Cost optimisation">Cost optimisation</option>
              </select>
            </label>

            <label>
              <span>Region</span>
              <select id="region" name="region" required>
                <option value="">Select region</option>
                <option value="South Africa">South Africa</option>
                <option value="Sub-Saharan Africa">Sub-Saharan Africa</option>
                <option value="EMEA">EMEA</option>
                <option value="Global">Global</option>
              </select>
            </label>

            <div class="button-row full-width">
              <button class="primary-btn" type="submit">Generate Solution</button>
              <button class="secondary-btn" type="button" id="populateDemoBtn">Load Banking Demo</button>
            </div>
          </form>
        </div>
      </section>

      <section class="right-panel">
        <div class="demo-stage glass">
          <div class="stage-head">
            <div>
              <span class="section-label">AI Output</span>
              <h3>Partner-ready recommendation</h3>
            </div>
            <div class="stage-badges">
              <span class="mini-badge">Vendor-aligned</span>
              <span class="mini-badge">Proposal-ready</span>
            </div>
          </div>

          <div id="emptyState" class="empty-state">
            <div class="empty-icon">⚡</div>
            <h4>Ready for a live walkthrough</h4>
            <p>Enter a partner scenario on the left, then generate a solution recommendation.</p>
          </div>

          <div id="thinkingState" class="thinking-state hidden">
            <div class="thinking-ring"></div>
            <div class="thinking-copy">
              <h4>Analyzing requirements...</h4>
              <ul class="thinking-steps" id="thinkingSteps">
                <li class="active">Interpreting customer need</li>
                <li>Matching vendor portfolio</li>
                <li>Building architecture recommendation</li>
                <li>Preparing proposal summary</li>
              </ul>
            </div>
          </div>

          <div id="resultsState" class="results-state hidden">
            <div class="summary-bar">
              <div>
                <span class="summary-label">Scenario</span>
                <strong id="scenarioTitle">Banking | 2000 users</strong>
              </div>
              <button class="ghost-btn" id="proposalBtn" type="button">Generate Proposal View</button>
            </div>

            <div class="solution-grid">
              <article class="solution-card network">
                <div class="solution-icon">🌐</div>
                <div>
                  <span class="solution-type">Network Layer</span>
                  <h4 id="networkTitle">Cisco SD-WAN</h4>
                  <p id="networkDesc">Secure, resilient branch and hybrid connectivity for distributed users.</p>
                </div>
              </article>

              <article class="solution-card security">
                <div class="solution-icon">🛡️</div>
                <div>
                  <span class="solution-type">Security Layer</span>
                  <h4 id="securityTitle">Palo Alto NGFW</h4>
                  <p id="securityDesc">Centralised policy enforcement and threat prevention across hybrid environments.</p>
                </div>
              </article>

              <article class="solution-card endpoint">
                <div class="solution-icon">💻</div>
                <div>
                  <span class="solution-type">Endpoint Protection</span>
                  <h4 id="endpointTitle">CrowdStrike Falcon</h4>
                  <p id="endpointDesc">AI-driven endpoint detection and response for modern workforces.</p>
                </div>
              </article>

              <article class="solution-card identity">
                <div class="solution-icon">🔐</div>
                <div>
                  <span class="solution-type">Identity</span>
                  <h4 id="identityTitle">Okta Identity</h4>
                  <p id="identityDesc">Strong identity and conditional access for secure user experiences.</p>
                </div>
              </article>
            </div>

            <div class="insight-panels">
              <div class="insight-panel">
                <span class="section-label">Architecture Summary</span>
                <p id="architectureSummary">
                  Recommended architecture prioritises secure access, resilient connectivity, and layered protection
                  for a hybrid workforce operating across regulated environments.
                </p>
              </div>
              <div class="insight-panel revenue-panel">
                <span class="section-label">Revenue Signal</span>
                <p id="revenueSignal">This recommendation creates a strong cross-sell opportunity across networking, security, endpoint, and identity.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline glass">
          <div class="card-head compact">
            <div>
              <span class="section-label">Motion Logic</span>
              <h3>How the experience flows</h3>
            </div>
          </div>
          <div class="flow-line">
            <div class="flow-step active">
              <span>1</span>
              <strong>Partner enters need</strong>
            </div>
            <div class="flow-step">
              <span>2</span>
              <strong>AI interprets intent</strong>
            </div>
            <div class="flow-step">
              <span>3</span>
              <strong>Vendors matched</strong>
            </div>
            <div class="flow-step">
              <span>4</span>
              <strong>Proposal-ready output</strong>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div class="modal hidden" id="proposalModal" aria-hidden="true">
    <div class="modal-card glass">
